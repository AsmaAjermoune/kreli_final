    {
      "file": "frontend/src/middleware.ts",
      "reason": "Handles locale routing for ALL pages — but does NOT do auth (that's client-side per layout.tsx)"
    },
    {
      "file": "backend/src/controllers/materiels.controller.js",
      "reason": "Public endpoints (Asmaa), owner CRUD (Youssef), admin moderation (Sara) all in same file"
    },
    {
      "file": "frontend/src/components/Navbar.tsx",
      "reason": "Global component — uses useAuth (Ahmed) and useI18n (Asmaa), rendered on every page"
    },
    {
