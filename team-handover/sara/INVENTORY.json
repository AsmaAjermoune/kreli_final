{
  "member": "Sara",
  "domain": "Admin Panel",
  "pages": [
    "frontend/src/app/dashboard/admin/page.tsx",
    "frontend/src/app/dashboard/admin/users/page.tsx",
    "frontend/src/app/dashboard/admin/categories/page.tsx",
    "frontend/src/app/dashboard/admin/litiges/page.tsx",
    "frontend/src/app/dashboard/admin/locations/page.tsx",
    "frontend/src/app/dashboard/admin/materiels/page.tsx",
    "frontend/src/app/dashboard/admin/paiements/page.tsx"
  ],
  "components": [
    "frontend/src/components/dashboard/AdminSidebar.tsx",
    "frontend/src/components/dashboard/DashboardUI.tsx (StatCard - shared with Youssef)"
  ],
  "hooks": [
    "frontend/src/context/AuthContext.tsx (shared - useAuth for admin guard)"
  ],
  "models": [
    "backend/src/models/Categorie.js",
    "backend/src/models/Litige.js",
    "backend/src/models/CommissionConfig.js (shared with Youssef)",
    "backend/src/models/User.js (shared - admin manages statut)",
    "backend/src/models/Paiement.js (shared - admin oversight)",
    "backend/src/models/Location.js (shared - admin stats)",
    "backend/src/models/Materiel.js (shared - admin moderation)"
  ],
  "controllers": [
    "backend/src/controllers/users.controller.js (getAllUsers, updateUser, deleteUser)",
    "backend/src/controllers/categories.controller.js",
    "backend/src/controllers/litiges.controller.js",
    "backend/src/controllers/paiements.controller.js (getAllPaiements, updatePaiementStatut, getAdminPaiementsStats)",
    "backend/src/controllers/locations.controller.js (getAdminStats, getAllLocations)",
    "backend/src/controllers/materiels.controller.js (admin: featured toggle, force delete, admin stats)"
  ],
  "routes": [
    "backend/src/routes/users.routes.js",
    "backend/src/routes/categories.routes.js",
    "backend/src/routes/litiges.routes.js",
    "backend/src/routes/paiements.routes.js",
    "backend/src/routes/locations.routes.js (admin endpoints)",
    "backend/src/routes/materiels.routes.js (admin endpoints)"
  ],
  "middlewares": [
    "backend/src/middleware/auth.middleware.js (requireRole('admin') - shared)",
    "backend/src/middleware/upload.middleware.js (shared - category images)"
  ],
  "services": [],
  "sockets": [
    "backend/src/socket/index.js (shared - dispute resolution notifications)"
  ],
  "dependencies": {
    "frontend": ["react", "next/link", "lucide-react", "framer-motion"],
    "backend": ["mongoose (aggregation)", "express-validator", "multer (shared)"]
  },
  "api_endpoints": [
    "GET /api/v1/users",
    "PATCH /api/v1/users/:id",
    "DELETE /api/v1/users/:id",
    "GET /api/v1/categories",
    "POST /api/v1/categories",
    "PUT /api/v1/categories/:id",
    "DELETE /api/v1/categories/:id",
    "GET /api/v1/litiges",
    "GET /api/v1/litiges/:id",
    "PATCH /api/v1/litiges/:id/assign",
    "PATCH /api/v1/litiges/:id/resolve",
    "GET /api/v1/paiements",
    "PATCH /api/v1/paiements/:id",
    "GET /api/v1/locations (admin)",
    "GET /api/v1/locations/stats",
    "PATCH /api/v1/materiels/:id/featured",
    "DELETE /api/v1/materiels/:id (admin force)"
  ],
  "shared_files": [
    {
      "file": "frontend/src/components/dashboard/DashboardUI.tsx",
      "reason": "StatCard component is used by both admin (Sara) and proprietaire (Youssef) dashboards"
    },
    {
      "file": "backend/src/controllers/locations.controller.js",
      "reason": "Contains admin stats (Sara), locataire endpoints (Meriem), and proprietaire endpoints (Youssef)"
    },
    {
      "file": "backend/src/controllers/materiels.controller.js",
      "reason": "Contains owner CRUD (Youssef), public listing (Asmaa), and admin moderation (Sara)"
    },
    {
      "file": "backend/src/controllers/paiements.controller.js",
      "reason": "Contains admin view (Sara), locataire view (Meriem), and owner view (Youssef)"
    },
    {
      "file": "backend/src/models/CommissionConfig.js",
      "reason": "Admin configures it (Sara); owner rentals read it at creation time (Youssef)"
    }
  ]
}
