PORT=5000
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/locamat?retryWrites=true&w=majority
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d

# Frontend URL for CORS (e.g. https://your-frontend.vercel.app)
CLIENT_URL=http://localhost:3000

# Email — leave blank to disable email sending
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=LocaMat <noreply@locamat.ma>
